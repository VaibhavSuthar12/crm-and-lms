                { "key": "assigned_to", "value": "1",       "disabled": true, "description": "Filter by user ID" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK — Paginated",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"current_page\": 1,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"title\": \"Enterprise Software Deal\",\n      \"first_name\": \"Alice\",\n      \"last_name\": \"Smith\",\n      \"email\": \"alice@acme.com\",\n      \"phone\": \"+91-9876543210\",\n      \"company\": \"Acme Corp\",\n      \"source\": \"Website\",\n      \"status\": \"New\",\n      \"value\": \"50000.00\",\n      \"assigned_to\": 3,\n      \"created_by\": 1,\n      \"assignee\": { \"id\": 3, \"name\": \"Sales Executive\" }\n    }\n  ],\n  \"per_page\": 15,\n  \"total\": 1\n}"
