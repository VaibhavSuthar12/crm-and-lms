            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Enterprise Software Deal\",\n  \"first_name\": \"Alice\",\n  \"last_name\": \"Smith\",\n  \"email\": \"alice@acme.com\",\n  \"phone\": \"+91-9876543210\",\n  \"company\": \"Acme Corp\",\n  \"source\": \"Website\",\n  \"status\": \"New\",\n  \"value\": 50000,\n  \"notes\": \"Interested in enterprise plan\",\n  \"assigned_to\": 3\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Lead created successfully.\",\n  \"lead\": {\n    \"id\": 1,\n    \"title\": \"Enterprise Software Deal\",\n    \"status\": \"New\",\n    \"created_by\": 1\n  }\n}"
            },
