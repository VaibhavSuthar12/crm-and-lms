{
  "info": {
    "name": "CRM Backend API — Laravel 12",
    "_postman_id": "crm-laravel-12-collection",
    "description": "Complete CRM Backend REST API built with Laravel 12, Sanctum Auth, and Spatie Permissions.\n\n## Setup\n1. Set `base_url` variable to `http://localhost:8000`\n2. Run **Login** request — token is auto-saved to `token` variable\n3. All protected requests use Bearer token automatically\n\n## Roles\n- **Admin** → admin@crm.com / Admin@1234\n- **Sales Manager** → manager@crm.com / Manager@1234\n- **Sales Executive** → exec@crm.com / Exec@1234",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:8000", "type": "string" },
    { "key": "token",       "value": "",                      "type": "string" },
    { "key": "lead_id",     "value": "1",                     "type": "string" },
    { "key": "customer_id", "value": "1",                     "type": "string" },
    { "key": "task_id",     "value": "1",                     "type": "string" },
    { "key": "user_id",     "value": "1",                     "type": "string" },
    { "key": "contact_id",  "value": "1",                     "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"role\": \"Sales Executive\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"User registered successfully.\",\n  \"user\": {\n    \"id\": 4,\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"is_active\": true,\n    \"roles\": [{ \"name\": \"Sales Executive\" }]\n  },\n  \"token\": \"1|abcdef...\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.test('Token saved', () => pm.expect(res.token).to.be.a('string'));",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@crm.com\",\n  \"password\": \"Admin@1234\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Login successful.\",\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"CRM Admin\",\n    \"email\": \"admin@crm.com\",\n    \"roles\": [{ \"name\": \"Admin\" }]\n  },\n  \"token\": \"1|abcdef...\"\n}"
            },
            {
              "name": "401 Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Invalid credentials.\"\n}"
            }
          ]
        },
        {
          "name": "Me (Profile)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"CRM Admin\",\n    \"email\": \"admin@crm.com\",\n    \"is_active\": true,\n    \"roles\": [{ \"name\": \"Admin\" }],\n    \"permissions\": []\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
