              "body": "{\n  \"stats\": {\n    \"total_leads\": 142,\n    \"total_customers\": 38,\n    \"todays_followups\": 5,\n    \"overdue_tasks\": 3,\n    \"conversion_rate\": 26.76\n  },\n  \"leads_by_status\": {\n    \"New\": 40,\n    \"Contacted\": 32,\n    \"Qualified\": 28,\n    \"Proposal Sent\": 15,\n    \"Won\": 20,\n    \"Lost\": 7\n  },\n  \"recent_activities\": []\n}"
            }
