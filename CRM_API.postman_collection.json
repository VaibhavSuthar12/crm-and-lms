              "body": "{\n  \"message\": \"Lead converted to customer successfully.\",\n  \"customer\": {\n    \"id\": 1,\n    \"first_name\": \"Alice\",\n    \"last_name\": \"Smith\",\n    \"email\": \"alice@acme.com\",\n    \"lead_id\": 1\n  }\n}"
            },
