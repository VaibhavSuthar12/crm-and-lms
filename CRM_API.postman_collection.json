              "name": "422 Validation Error",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"Validation failed.\",\n  \"errors\": {\n    \"title\": [\"The title field is required.\"],\n    \"first_name\": [\"The first name field is required.\"]\n  }\n}"
            }
